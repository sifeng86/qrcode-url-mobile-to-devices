# Runtime
NODE_ENV=production
APP_PORT=8080
PUBLIC_BASE_URL=
BASE_PATH=
SESSION_TTL_MINUTES=20
CLEANUP_INTERVAL_MS=300000
FILE_STORAGE_DRIVER=disabled
FILE_MAX_BYTES=26214400
FILE_UPLOAD_URL_TTL_SECONDS=300
FILE_DOWNLOAD_URL_TTL_SECONDS=60
FILE_RETENTION_MINUTES=60
FILE_RETENTION_MIN_MINUTES=5
FILE_RETENTION_MAX_MINUTES=1440
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Application database connection
DB_HOST=db
DB_PORT=3306
DB_USER=qrcode
DB_PASSWORD=qrcode_password
DB_NAME=qrcode_relay
DB_TABLE=relay_sessions
DB_SHARE_TABLE=share_items
DB_CONNECT_RETRIES=20
DB_CONNECT_RETRY_MS=3000

# Local MySQL container defaults
MYSQL_ROOT_PASSWORD=qrcode_root_password
MYSQL_DATABASE=qrcode_relay
MYSQL_USER=qrcode
MYSQL_PASSWORD=qrcode_password
